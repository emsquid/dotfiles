#!/bin/zsh

command=$1
id="@DEFAULT_AUDIO_SINK@"

# change volume
if [ "$command" = "up" ]; then
    wpctl get-volume $id | grep -v "MUTED" && wpctl set-volume $id 5%+ -l 1
elif [ "$command" = "down" ]; then
    wpctl get-volume $id | grep -v "MUTED" && wpctl set-volume $id 5%-
elif [ "$command" = "mute" ]; then
    wpctl set-mute $id toggle
else 
    wpctl set-volume $id | grep -v "MUTED" && wpctl set-volume $id $command
fi

# log it
logdir="$HOME/.local/state/var/"
logfile="$logdir/volume.log"
wpctl_output=$(wpctl get-volume $id) 
volume=$(printf "%.0f" "$(("$(echo "$wpctl_output" | cut -d ' ' -f 2)" * 100))")

if echo "$wpctl_output" | grep "MUTED"; then
    icon="婢" 
elif [ "$volume" -gt 67 ]; then
    icon="墳"
elif [ "$volume" -gt 33 ]; then
    icon="奔"
else
    icon="奄"
fi

mkdir -p "$logdir"
tail -1 "$logfile" > "$logfile"

if echo "$wpctl_output" | grep "MUTED"; then
    echo "{\"icon\": \"$icon \"}" >> "$logdir/volume.log"
else
    echo "{\"icon\": \"$icon \", \"volume\": $volume}" >> "$logdir/volume.log"
fi
